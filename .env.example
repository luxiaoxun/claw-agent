# =============================================================================
# ClawAgent - 环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并根据实际情况修改配置值
# cp .env.example .env
# =============================================================================

# LLM配置
OPENAI_API_KEY=your-api-key
LLM_MODEL=your-model-name
OPENAI_BASE_URL=http://your-gateway.example.com

# 本地Elasticsearch配置
ES_HOSTS=http://localhost:9200

# MCP配置
# MCP_SERVER_URL=http://127.0.0.1:8000/sse